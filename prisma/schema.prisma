generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum Role {
  admin
  manager
  member
}

enum Plan {
  free
  basic
  professional
  organization
  enterprise
}

enum SubscriptionStatus {
  active
  trialing
  past_due
  cancelled
}

enum EmailStatus {
  verified
  guessed
  unavailable
  bounced
}

enum Seniority {
  c_suite
  vp
  director
  manager
  senior
  entry
}

enum Stage {
  cold
  approaching
  replied
  interested
  not_interested
  dnc
}

enum EnrichmentStatus {
  pending
  enriched
  failed
  stale
}

model Organization {
  id                   String             @id @default(uuid()) @db.Uuid
  name                 String             @db.VarChar(255)
  domain               String             @unique @db.VarChar(255)
  plan                 Plan               @default(free)
  subscription_status  SubscriptionStatus @default(trialing)
  credits_remaining    Int                @default(0)
  monthly_credit_limit Int                @default(1000)
  billing_email        String?            @db.VarChar(255)
  created_at           DateTime           @default(now()) @db.Timestamp(6)
  updated_at           DateTime           @default(now()) @updatedAt @db.Timestamp(6)

  teams     Team[]
  users     User[]
  contacts  Contact[]
  companies Company[]
  searches  SearchQuery[]
  prospects Prospect[]
}

model Team {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @db.VarChar(255)
  org_id     String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamp(6)

  organization Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  users        User[]
}

model User {
  id               String    @id @default(uuid()) @db.Uuid
  email            String    @unique @db.VarChar(255)
  first_name       String    @db.VarChar(100)
  last_name        String    @db.VarChar(100)
  role             Role      @default(member)
  org_id           String    @db.Uuid
  team_id          String?   @db.Uuid
  avatar_url       String?   @db.Text
  timezone         String    @default("UTC") @db.VarChar(50)
  daily_send_limit Int       @default(100)
  last_login_at    DateTime? @db.Timestamp(6)
  created_at       DateTime  @default(now()) @db.Timestamp(6)
  updated_at       DateTime  @default(now()) @updatedAt @db.Timestamp(6)

  organization Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  team         Team?        @relation(fields: [team_id], references: [id], onDelete: SetNull)
  contacts     Contact[]    @relation("ContactOwner")
}

model Contact {
  id                String           @id @default(uuid()) @db.Uuid
  org_id            String           @db.Uuid
  first_name        String?          @db.VarChar(100)
  last_name         String?          @db.VarChar(100)
  email             String?          @db.VarChar(255)
  email_status      EmailStatus?
  email_confidence  Int              @default(0)
  phone_direct      String?          @db.VarChar(20)
  phone_mobile      String?          @db.VarChar(20)
  phone_hq          String?          @db.VarChar(20)
  title             String?          @db.VarChar(255)
  seniority         Seniority?
  department        String?          @db.VarChar(100)
  company_id        String?          @db.Uuid
  linkedin_url      String?          @db.Text
  city              String?          @db.VarChar(100)
  state             String?          @db.VarChar(100)
  country           String?          @db.VarChar(100)
  stage             Stage            @default(cold)
  owner_id          String?          @db.Uuid
  lead_score        Int              @default(0)
  enrichment_status EnrichmentStatus @default(pending)
  last_enriched_at  DateTime?        @db.Timestamp(6)
  source            String?          @db.VarChar(100)
  tags              String[]         @default([])
  created_at        DateTime         @default(now()) @db.Timestamp(6)
  updated_at        DateTime         @default(now()) @updatedAt @db.Timestamp(6)

  organization Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  company      Company?     @relation(fields: [company_id], references: [id], onDelete: SetNull)
  owner        User?        @relation("ContactOwner", fields: [owner_id], references: [id], onDelete: SetNull)

  @@unique([email, org_id], name: "email_org_id")
}

model Company {
  id                String           @id @default(uuid()) @db.Uuid
  org_id            String           @db.Uuid
  name              String           @db.VarChar(255)
  domain            String           @db.VarChar(255)
  industry          String?          @db.VarChar(100)
  employee_count    Int?
  annual_revenue    BigInt?
  founded_year      Int?
  description       String?          @db.Text
  linkedin_url      String?          @db.Text
  website_url       String?          @db.Text
  address           String?          @db.Text
  city              String?          @db.VarChar(100)
  state             String?          @db.VarChar(100)
  country           String?          @db.VarChar(100)
  logo_url          String?          @db.Text
  enrichment_status EnrichmentStatus @default(pending)
  created_at        DateTime         @default(now()) @db.Timestamp(6)
  updated_at        DateTime         @default(now()) @updatedAt @db.Timestamp(6)

  organization Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  contacts     Contact[]

  @@unique([domain, org_id], name: "domain_org_id")
}

model SearchQuery {
  id         String   @id @default(uuid()) @db.Uuid
  org_id     String   @db.Uuid
  query      String   @db.Text
  location   String?  @db.VarChar(255)
  source     String   @default("osm") // osm or google
  created_at DateTime @default(now()) @db.Timestamp(6)

  organization Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  prospects    Prospect[]
}

model Prospect {
  id            String   @id @default(uuid()) @db.Uuid
  org_id        String   @db.Uuid
  search_id     String?  @db.Uuid
  name          String   @db.VarChar(255)
  website       String?  @db.VarChar(255)
  address       String?  @db.Text
  emails        String[] @default([])
  status        String   @default("found") // found, enriched, saved
  created_at    DateTime @default(now()) @db.Timestamp(6)
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamp(6)

  organization Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  search_query SearchQuery? @relation(fields: [search_id], references: [id], onDelete: SetNull)
}
